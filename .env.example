# ── Server ──────────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_ADDR=:8080
LOG_LEVEL=info          # debug | info | warn | error
VERSION=dev

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# docker compose sets DATABASE_URL automatically from the values below.
# When running the binary directly (outside Docker), set DATABASE_URL explicitly.
POSTGRES_USER=memory
POSTGRES_PASSWORD=memory      # change in production
POSTGRES_DB=memory
POSTGRES_PORT=5432            # host port exposed by docker compose
DB_DIR=./db                   # host path where PostgreSQL data is persisted

# To use SQLite instead of PostgreSQL, leave DATABASE_URL empty and set:
# DATA_DIR=./data              # host path for SQLite file
DATABASE_URL=                  # set by docker-compose automatically; override here for external Postgres

# ── Team ────────────────────────────────────────────────────────────────────
TEAM_ID=default
SUPERADMIN_KEY=          # set to a long random string in production

# ── Auth ────────────────────────────────────────────────────────────────────
DEV_BYPASS_AUTH=false    # set true ONLY in development; never in production

# ── Embeddings (Ollama) ──────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_PORT=11434        # exposed host port when using docker compose --profile ollama
OLLAMA_DATA_DIR=./ollama-data
EMBEDDING_DIM=768

# ── LLM (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=       # required for pipeline, agent generation, prompt_suggest
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AGENT_MODEL=claude-sonnet-4-6

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_INTERVAL=1h           # Go duration: 30m, 2h, etc.
PIPELINE_MIN_ENTRIES=10
CLUSTER_THRESHOLD=0.85         # cosine similarity threshold (0,1]

# ── MCP HTTP/SSE transport (optional) ────────────────────────────────────────
MCP_HTTP_ADDR=           # e.g. :9090  — leave empty to disable HTTP MCP
MCP_HTTP_PATH=/mcp

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_RPS=60        # per-IP requests per second (token bucket); 0 to disable
TRUST_XFF=false          # set true ONLY when deployed behind a known reverse proxy; exposes rate-limit bypass otherwise
