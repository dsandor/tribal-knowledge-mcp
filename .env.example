# ── Server ──────────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_ADDR=:8080
LOG_LEVEL=info          # debug | info | warn | error
VERSION=dev

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# docker compose sets DATABASE_URL automatically from the values below.
# When running the binary directly (outside Docker), set DATABASE_URL explicitly.
POSTGRES_USER=memory
POSTGRES_PASSWORD=memory      # change in production
POSTGRES_DB=memory
POSTGRES_PORT=5432            # host port exposed by docker compose
DB_DIR=./db                   # host path where PostgreSQL data is persisted

# To use SQLite instead of PostgreSQL, leave DATABASE_URL empty and set DATABASE_PATH.
DATABASE_URL=                  # set by docker-compose automatically; override here for external Postgres
DATABASE_PATH=knowledge.db     # SQLite file; ignored when DATABASE_URL is set. Prefer an ABSOLUTE path
                               # (resolved relative to the server's working directory otherwise).

# ── Team ────────────────────────────────────────────────────────────────────
TEAM_ID=default
SUPERADMIN_KEY=          # set to a long random string in production

# ── Auth ────────────────────────────────────────────────────────────────────
DEV_BYPASS_AUTH=false    # set true ONLY in development; never in production
# OIDC / OAuth single sign-on (Zitadel, Okta, etc.). See docs/oauth-providers.md.
# Issuer, client ID, and redirect URL are configured at runtime via the admin UI / API.
# Only the client secret is read from the environment (never stored in the DB):
OIDC_CLIENT_SECRET=      # required when the auth provider is set to 'oidc'

# ── Embeddings (Ollama) ──────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
OLLAMA_PORT=11434        # exposed host port when using docker compose --profile ollama
OLLAMA_DATA_DIR=./ollama-data
EMBEDDING_DIM=768

# ── Embedding chunking (defaults; overridable per-team in Settings) ───────────
# Large knowledge items are split into multiple embedding vectors so nothing is
# lost to the embedding model's context window. 0/unset on a team falls back to
# these env defaults.
EMBEDDING_MAX_TOKENS=8192   # per-chunk token budget (the embedding model's context window)
EMBEDDING_CHUNK_OVERLAP=128 # tokens of overlap repeated between adjacent chunks
EMBEDDING_MAX_CHUNKS=64     # safety cap on chunks per item

# ── LLM (Anthropic) ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=       # required for pipeline, agent generation, prompt_suggest
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AGENT_MODEL=claude-sonnet-4-6

# ── LLM Provider ─────────────────────────────────────────────────────────────
# LLM provider for analysis/agents/improvement: anthropic (default) or ollama
LLM_PROVIDER=
# Ollama CHAT model used when LLM_PROVIDER=ollama (separate from OLLAMA_MODEL, the embedding model)
OLLAMA_LLM_MODEL=

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_INTERVAL=1h           # Go duration: 30m, 2h, etc.
PIPELINE_MIN_ENTRIES=10
CLUSTER_THRESHOLD=0.85         # cosine similarity threshold (0,1]

# ── MCP Streamable HTTP transport (optional) ─────────────────────────────────
# Set MCP_HTTP_ADDR to enable the remote MCP endpoint; leave empty for stdio-only.
# The endpoint is authenticated: clients must send Authorization: Bearer <api_key>.
MCP_HTTP_ADDR=:8081      # e.g. :8081 — leave empty to disable HTTP MCP
MCP_HTTP_PATH=/mcp
MCP_HTTP_PORT=8081       # host port published by docker compose for the MCP endpoint

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_RPS=60        # per-IP requests per second (token bucket); 0 to disable
TRUST_XFF=false          # set true ONLY when deployed behind a known reverse proxy; exposes rate-limit bypass otherwise
